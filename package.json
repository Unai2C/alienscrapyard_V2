{
  "name": "dcl-project",
  "version": "1.0.0",
  "description": "SDK7 Template scene",
  "scripts": {
    "start": "sdk-commands start",
    "start:mobile": "sdk-commands start --mobile",
    "deploy": "sdk-commands deploy",
    "build": "sdk-commands build --production",
    "build:dev": "sdk-commands build",
    "upgrade-sdk": "npm install --save-dev @dcl/sdk@latest",
    "upgrade-sdk:next": "npm install --save-dev @dcl/sdk@next",
    "server-logs": "npx -y @dcl/sdk-commands@7.23.4-26106700711.commit-2afa13b sdk-server-logs",
    "server-logs:prod": "npx -y @dcl/sdk-commands@7.23.4-26106700711.commit-2afa13b sdk-server-logs --world alienscrapyard.dcl.eth --position=0,0",
    "server-logs:world": "npx -y @dcl/sdk-commands@7.23.4-26106700711.commit-2afa13b sdk-server-logs --world alienscrapyard.dcl.eth"
  },
  "devDependencies": {
    "@dcl/js-runtime": "7.24.0",
    "@dcl/sdk": "^7.24.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=6.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "none"
  }
}