{
  "name": "dcl-project",
  "version": "1.0.0",
  "description": "SDK7 Template scene",
  "scripts": {
    "start": "sdk-commands start",
    "start:mobile": "sdk-commands start --mobile",
    "deploy": "sdk-commands build --customEntryPoint && sdk-commands deploy --skip-build",
    "build": "sdk-commands build --customEntryPoint",
    "build:prod": "sdk-commands build --customEntryPoint --production",
    "upgrade-sdk": "npm install --save-dev @dcl/sdk@latest",
    "upgrade-sdk:next": "npm install --save-dev @dcl/sdk@next",
    "server-logs": "npx -y @dcl/sdk-commands@7.24.4-28592331167.commit-697ce9e sdk-server-logs",
    "server-logs:prod": "npx -y @dcl/sdk-commands@7.24.4-28592331167.commit-697ce9e sdk-server-logs --world alienscrapyard.dcl.eth --position=0,0",
    "server-logs:world": "npx -y @dcl/sdk-commands@7.24.4-28592331167.commit-697ce9e sdk-server-logs --world alienscrapyard.dcl.eth"
  },
  "devDependencies": {
    "@dcl/js-runtime": "7.24.4",
    "@dcl/sdk": "7.24.4"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=6.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "none"
  }
}