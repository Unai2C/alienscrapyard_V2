{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react",
    "jsxFactory": "ReactEcs.createElement",
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "types": ["@dcl/sdk"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}